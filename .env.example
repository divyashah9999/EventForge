# Google Gemini API Key
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# Notion Integration
# Get your token from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_your_notion_internal_integration_token

# The ID of the Notion page where you want workspaces to be created
# Found in the URL of your target parent page
NOTION_MASTER_PAGE_ID=notion_page_id_hex_string
